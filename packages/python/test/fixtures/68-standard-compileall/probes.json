{
  "probes": [
    {
      "logMustContain": "Compiling Python bytecode"
    },
    {
      "path": "/",
      "mustContain": "\"app_pyc\":true"
    },
    {
      "path": "/",
      "mustContain": "\"vendor_pyc\":true"
    },
    {
      "path": "/",
      "mustContain": "\"ok\":true"
    }
  ]
}
